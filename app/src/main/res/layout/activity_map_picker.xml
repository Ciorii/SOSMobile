<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:iconifiedByDefault="false"
        android:queryHint="Cauta o locatie"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvMapHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Atinge sau tine apasat pe harta pentru a selecta locatia"
        android:layout_marginBottom="8dp" />

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvRadiusValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Raza: 100m"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderRadius"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnConfirmZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salveaza zona" />

</LinearLayout>
